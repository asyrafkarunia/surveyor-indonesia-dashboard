# ============================================================================
# MARS Dashboard — Production Environment Configuration
# ============================================================================
# PERINGATAN: Jangan commit file .env ke repository!
# Salin file ini menjadi .env di server production dan isi semua nilai.
# ============================================================================

APP_NAME=MARS
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://marssipku.com
FRONTEND_URL=https://marssipku.com

# Logging — gunakan 'daily' agar log di-rotasi otomatis (retensi 14 hari)
LOG_CHANNEL=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# Database — WAJIB isi password yang kuat
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=mars_db
DB_USERNAME=mars_user
DB_PASSWORD=GANTI_DENGAN_PASSWORD_KUAT

# Drivers
BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=true

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Email — gunakan App Password dari Google (https://myaccount.google.com/apppasswords)
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=GANTI_DENGAN_EMAIL
MAIL_PASSWORD=GANTI_DENGAN_APP_PASSWORD
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@marssipku.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Domain — sesuaikan dengan domain production
SANCTUM_STATEFUL_DOMAINS=marssipku.com
CORS_ALLOWED_ORIGINS=https://marssipku.com
SESSION_DOMAIN=marssipku.com

# Rate Limit — 120 request/menit per user (2 request/detik)
API_RATE_LIMIT=120
