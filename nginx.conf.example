# ============================================================================
# MARS Dashboard — Nginx Configuration Example
# ============================================================================
# Cara penggunaan:
# 1. Salin file ini ke /etc/nginx/sites-available/marssipku.com
# 2. Ganti 'marssipku.com' dengan domain sebenarnya
# 3. Sesuaikan path /var/www/mars-dashboard dengan lokasi project
# 4. Buat symlink: ln -s /etc/nginx/sites-available/marssipku.com /etc/nginx/sites-enabled/
# 5. Test: nginx -t
# 6. Reload: systemctl reload nginx
#
# Untuk SSL (HTTPS), jalankan setelah konfigurasi dasar:
#   apt install certbot python3-certbot-nginx
#   certbot --nginx -d marssipku.com
# ============================================================================

# ── Rate Limiting Zone ──
# Membatasi request berlebihan dari satu IP (anti-DDoS sederhana)
limit_req_zone $binary_remote_addr zone=api:10m rate=10r/s;

server {
    listen 80;
    server_name marssipku.com;

    # Redirect HTTP → HTTPS (aktifkan setelah SSL terpasang)
    # return 301 https://$host$request_uri;

    # ── Sementara (sebelum SSL) ──
    root /var/www/mars-dashboard/dist;
    index index.html;

    # ── Frontend (React SPA) ──
    # Semua path yang bukan API atau file statis diarahkan ke index.html
    location / {
        try_files $uri $uri/ /index.html;
    }

    # ── Backend API (Laravel) ──
    # Proxy pass ke PHP-FPM melalui Laravel
    location /api {
        # Rate limiting: 10 req/detik dengan burst 20
        limit_req zone=api burst=20 nodelay;

        proxy_pass http://127.0.0.1:8000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # Timeout settings
        proxy_connect_timeout 30s;
        proxy_send_timeout 30s;
        proxy_read_timeout 60s;
    }

    # ── Laravel Storage (Avatars, Uploads) ──
    location /storage {
        alias /var/www/mars-dashboard/backend/storage/app/public;
        expires 7d;
        add_header Cache-Control "public, immutable";
    }

    # ── Static Assets (JS, CSS, Images) ──
    # Vite menambahkan hash pada filename, jadi aman di-cache lama
    location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot)$ {
        expires 1y;
        add_header Cache-Control "public, immutable";
        access_log off;
    }

    # ── Gzip Compression ──
    gzip on;
    gzip_vary on;
    gzip_proxied any;
    gzip_comp_level 6;
    gzip_min_length 1024;
    gzip_types
        text/plain
        text/css
        text/javascript
        application/json
        application/javascript
        application/xml
        application/xml+rss
        image/svg+xml;

    # ── Security ──
    # Sembunyikan versi Nginx
    server_tokens off;

    # Blokir akses ke file sensitif
    location ~ /\.(?!well-known) {
        deny all;
    }

    # Blokir akses ke .env
    location ~ /\.env {
        deny all;
    }

    # Max upload size (sesuaikan dengan kebutuhan upload dokumen)
    client_max_body_size 20M;
}

